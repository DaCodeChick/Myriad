# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# Bot-to-Bot Communication Whitelist
# Comma-separated list of Discord bot user IDs that Myriad should respond to
# By default, Myriad ignores all bot messages. Add bot IDs here to allow communication.
# Example: WHITELISTED_BOT_IDS=1399732632325062878,987654321012345678
WHITELISTED_BOT_IDS=

# LLM API Configuration (Main Text Model)
LLM_API_KEY=your_openai_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4

# Universal Directives (Core System Rules)
# Global rules applied to ALL personas before character-specific behavior
# Format: Pipe-separated list of rules (Rule 1 | Rule 2 | Rule 3)
# If not set, system uses hardcoded defaults from AgentCore.DEFAULT_UNIVERSAL_RULES
# Example: UNIVERSAL_RULES=ALWAYS speak in first person | NEVER use asterisks for actions | Stay in character at all times
UNIVERSAL_RULES=

# Vision API Configuration (Split-Brain Vision Model)
VISION_API_KEY=not-needed
VISION_BASE_URL=http://localhost:5002/v1
VISION_MODEL=vision-model

# Memory Configuration (Hybrid Memory Architecture)
# Short-term memory: Last N messages for immediate conversation context
SHORT_TERM_MEMORY_LIMIT=10

# Vector Memory Configuration (Semantic Long-Term Memory)
# Enable ChromaDB semantic search for recalling relevant past conversations
VECTOR_MEMORY_ENABLED=true
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SEMANTIC_RECALL_LIMIT=5
CHROMA_DB_PATH=data/chroma_db

# Weighted Priority Memory System
# Controls how semantic similarity vs importance score affect memory retrieval
# Final score = (similarity × SIMILARITY_WEIGHT) + (importance × IMPORTANCE_WEIGHT)
# Values should sum to 1.0 for balanced scoring
MEMORY_SIMILARITY_WEIGHT=0.5
MEMORY_IMPORTANCE_WEIGHT=0.5

# Tool Use Configuration (Function Calling)
# Enable LLM tool/function calling capabilities
TOOLS_ENABLED=true
# Maximum number of tool call iterations per message (prevents infinite loops)
MAX_TOOL_ITERATIONS=5

# Database Configuration
# Main database for core state (user preferences, memories, limbic state, etc.)
MAIN_DB_PATH=data/myriad.db
# Knowledge graph database (entity extraction and relationships)
GRAPH_DB_PATH=data/knowledge_graph.db
# ChromaDB vector database path (semantic memory)
CHROMA_DB_PATH=data/chroma_db

# Spontaneous Autonomy Configuration (Circadian Rhythm Engine)
# How often the daemon checks for spontaneous outreach opportunities (in minutes)
AUTONOMY_CHECK_INTERVAL_MINUTES=60

# Logging Configuration (Debug & Monitoring)
# Separate toggles for console (terminal) and file (disk) logging
# Console logging: Real-time color-coded output to terminal
# File logging: Persistent logs written to timestamped files in logs/ directory

# Brain (Text LLM) Logging
ENABLE_BRAIN_CONSOLE_LOGGING=false  # Console: User messages, AI responses, thoughts, LLM API calls
ENABLE_BRAIN_FILE_LOGGING=false     # File: All brain activity to logs/brain_YYYY-MM-DD.log

# Eyes (Vision) Logging  
ENABLE_EYES_CONSOLE_LOGGING=false   # Console: Vision processing, appearance generation
ENABLE_EYES_FILE_LOGGING=false      # File: All vision activity to logs/eyes_YYYY-MM-DD.log

# Log Directory (where log files are stored)
LOG_DIR=logs

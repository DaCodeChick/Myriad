# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# LLM API Configuration (Main Text Model)
LLM_API_KEY=your_openai_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4

# Vision API Configuration (Split-Brain Vision Model)
VISION_API_KEY=not-needed
VISION_BASE_URL=http://localhost:5002/v1
VISION_MODEL=vision-model

# Memory Configuration
MEMORY_CONTEXT_LIMIT=50

# Vector Memory Configuration (Semantic RAG System)
VECTOR_MEMORY_ENABLED=true
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SEMANTIC_RECALL_LIMIT=5
CHROMA_DB_PATH=database/chroma_db

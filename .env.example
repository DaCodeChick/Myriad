# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# LLM API Configuration (Main Text Model)
LLM_API_KEY=your_openai_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4

# Vision API Configuration (Split-Brain Vision Model)
VISION_API_KEY=not-needed
VISION_BASE_URL=http://localhost:5002/v1
VISION_MODEL=vision-model

# Memory Configuration (Hybrid Memory Architecture)
# Short-term memory: Last N messages for immediate conversation context
SHORT_TERM_MEMORY_LIMIT=10

# Vector Memory Configuration (Semantic Long-Term Memory)
# Enable ChromaDB semantic search for recalling relevant past conversations
VECTOR_MEMORY_ENABLED=true
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SEMANTIC_RECALL_LIMIT=5
CHROMA_DB_PATH=data/chroma_db

# Tool Use Configuration (Function Calling)
# Enable LLM tool/function calling capabilities
TOOLS_ENABLED=true
# Maximum number of tool call iterations per message (prevents infinite loops)
MAX_TOOL_ITERATIONS=5

# Knowledge Graph Memory Configuration
# Enable knowledge graph for storing factual entity-relationship data
GRAPH_MEMORY_ENABLED=true
# Path to knowledge graph SQLite database
GRAPH_DB_PATH=data/knowledge_graph.db

# Limbic System Configuration (Emotional Neurochemistry)
# Enable limbic system for tracking emotional state via neurochemicals
LIMBIC_ENABLED=true
# Path to limbic state SQLite database
LIMBIC_DB_PATH=data/limbic_state.db
